meta {
  name: Import – Analyze
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/import/analyze
  body: multipartForm
  auth: none
}

body:multipart {
  datei: @file(/tmp/test_import.xlsx)
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
    expect(res.body.data).to.have.property("vorschau");
    expect(res.body.data).to.have.property("felder");
  });
}
