meta {
  name: Adressen – Stadt erstellen
  type: http
  seq: 2
}

post {
  url: {{baseUrl}}/adressen/staedte
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Magdeburg",
    "wikidata_id": "Q1733"
  }
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
    expect(res.body.data.name).to.equal("Magdeburg");
  });
}
