meta {
  name: Adressen – Straße erstellen
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/adressen/alle-strassen
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "name": "Hegelstraße",
    "stadt_id": 1,
    "wikidata_id": null,
    "wikipedia_name": null
  }
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
    expect(res.body.data.name).to.equal("Hegelstraße");
  });
}
