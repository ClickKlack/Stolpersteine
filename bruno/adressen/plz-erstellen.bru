meta {
  name: Adressen – PLZ erstellen
  type: http
  seq: 8
}

post {
  url: {{baseUrl}}/adressen/alle-plz
  body: json
  auth: none
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "plz": "39104",
    "stadt_id": 1
  }
}

tests {
  test("Status 200", function() {
    expect(res.status).to.equal(200);
    expect(res.body.data.plz).to.equal("39104");
  });
}
